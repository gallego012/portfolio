---
// Labs.astro — Infrastructure laboratory case studies grid
const labs = [
  {
    id: "lab-cicd-arch",
    number: "LAB_01",
    category: "Arquitectura · DevOps",
    title: "Arquitectura CI/CD — Este Portfolio",
    description:
      "Infraestructura serverless sobre Cloudflare Pages con integración y despliegue continuo (CI/CD), políticas de seguridad perimetral y DNS.",
    details: [
      "Pipeline: git push → GitHub → Edge CDN",
      "Zona DNS Autoritativa",
      "Hardening de Headers (CSP, HSTS)",
      "Reglas WAF y Rate Limiting",
    ],
    tags: ["Cloudflare", "Git", "CI/CD", "DNS", "Security Headers", "WAF"],
    linkDoc: "#labs",
    linkCode: "https://github.com/gallego012/portfolio",
    status: "DESPLEGADO",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  }
];
---

<section class="labs-section" id="labs" aria-labelledby="labs-title">
  <div class="container">
    <header class="section-header">
      <p class="section-label" aria-hidden="true">Documentación Técnica</p>
      <h2 class="section-title" id="labs-title">Laboratorios de Infraestructura</h2>
      <p class="section-subtitle">
        Documentación técnica interactiva de arquitecturas CI/CD, automatización de despliegues y gestión de seguridad web en entornos de producción activos.
      </p>
    </header>

    <div class="labs-grid" role="list">
      {labs.map((lab) => (
        <article class="lab-card" id={lab.id} role="listitem">
          <!-- Terminal header -->
          <div class="lab-terminal-header">
            <span class="lab-dot lab-dot--red"></span>
            <span class="lab-dot lab-dot--yellow"></span>
            <span class="lab-dot lab-dot--green"></span>
          </div>

          <div class="lab-card-content">
            <!-- Card header -->
          <div class="lab-card__header">
            <div class="lab-icon-wrapper" aria-hidden="true">
              <Fragment set:html={lab.icon} />
            </div>
            <div class="lab-meta">
              <span class="lab-number mono">{lab.number}</span>
              <span class={`lab-status mono lab-status--${lab.status.toLowerCase()}`}>
                <span class="status-indicator" aria-hidden="true"></span>
                {lab.status}
              </span>
            </div>
          </div>

          <!-- Category -->
          <p class="lab-category mono">{lab.category}</p>


          <h3 class="lab-title">{lab.title}</h3>


          <p class="lab-description">{lab.description}</p>


          <ul class="lab-details" aria-label="Detalles técnicos">
            {lab.details.map((detail) => (
              <li class="lab-detail-item">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="9 18 15 12 9 6"/>
                </svg>
                {detail}
              </li>
            ))}
          </ul>


          <div class="lab-tags" role="list" aria-label="Tecnologías utilizadas">
            {lab.tags.map((tag) => (
              <span class="lab-tag mono" role="listitem">{tag}</span>
            ))}
          </div>


          <div class="lab-actions">
            <button class="lab-btn lab-btn--primary js-open-readme" data-readme-url={lab.linkCode !== "https://github.com/gallego012" ? `https://raw.githubusercontent.com/${lab.linkCode.split('github.com/')[1]}/main/README.md` : ""} aria-label={`Leer documentación de ${lab.title}`} style="cursor: pointer;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
              Leer Documentación
            </button>
            <a href={lab.linkCode} class="lab-btn lab-btn--secondary" id={`${lab.id}-btn-code`} target="_blank" rel="noopener noreferrer" aria-label={`Ver código fuente de ${lab.title}`}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
              Ver Código Fuente
            </a>
          </div>
          </div>
        </article>
      ))}
    </div>
  </div>


  <div class="readme-modal" id="readme-modal" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="readme-modal-backdrop js-modal-close"></div>
    <div class="readme-modal-window">
      <div class="lab-terminal-header">
        <div class="terminal-dots-container" style="display: flex; gap: 8px;">
          <span class="lab-dot lab-dot--red js-modal-close" style="cursor: pointer;" title="Cerrar">
            <svg viewBox="0 0 14 14"><path d="M4 4 L10 10 M10 4 L4 10"></path></svg>
          </span>
          <span class="lab-dot lab-dot--yellow js-modal-minimize" style="cursor: pointer;" title="Minimizar">
            <svg viewBox="0 0 14 14"><line x1="3" y1="7" x2="11" y2="7"></line></svg>
          </span>
          <span class="lab-dot lab-dot--green js-modal-maximize" style="cursor: pointer;" title="Maximizar">
            <svg viewBox="0 0 14 14"><path d="M8.5 2.5 L11.5 2.5 L11.5 5.5 M11.5 2.5 L7 7 M5.5 11.5 L2.5 11.5 L2.5 8.5 M2.5 11.5 L7 7"></path></svg>
          </span>
        </div>
        <span class="lab-terminal-title mono">README.md</span>
        <div></div>
      </div>
      <div class="readme-modal-content-wrapper markdown-body" id="readme-modal-content">
        <div class="readme-loading">
          <svg class="loading-spinner" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg>
          <span class="mono">Conectando con GitHub...</span>
        </div>
      </div>
    </div>
  </div>


  <div id="readme-dock-pill" class="readme-dock-pill" role="button" aria-label="Restaurar Documentación">
    <div class="dock-icon-wrapper">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
    </div>
    <span class="mono">README.md</span>
  </div>
</section>

<style>
  .labs-section {
    padding: var(--section-padding) 0;
    background: linear-gradient(180deg, transparent 0%, rgba(17, 34, 64, 0.3) 50%, transparent 100%);
    position: relative;
  }

  .section-header {
    margin-bottom: 56px;
  }

  /* Grid */
  .labs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 28px;
  }

  /* Card */
  .lab-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: all var(--transition-normal);
    position: relative;
    overflow: hidden;
    animation: float 6s ease-in-out infinite;
  }

  .lab-card:nth-child(2) { animation-delay: 1.5s; }
  .lab-card:nth-child(3) { animation-delay: 3s; }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
    100% { transform: translateY(0px); }
  }

  /* Terminal Header Styles */
  .lab-terminal-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 18px;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-subtle);
  }

  .lab-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .lab-dot--red { background: #ff5f57; }
  .lab-dot--yellow { background: #ffbd2e; }
  .lab-dot--green { background: #28c840; }

  .lab-terminal-title {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-left: auto;
    margin-right: auto;
    letter-spacing: 0.05em;
  }

  .lab-card-content {
    padding: 24px 32px 32px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .lab-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--green-bright), transparent);
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .lab-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-6px);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.4),
      0 0 40px rgba(100, 255, 218, 0.06);
  }

  .lab-card:hover::before {
    opacity: 1;
  }

  /* Card header */
  .lab-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .lab-icon-wrapper {
    width: 60px;
    height: 60px;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green-bright);
    transition: all var(--transition-normal);
  }

  .lab-card:hover .lab-icon-wrapper {
    background: var(--green-dim);
    border-color: var(--border-accent);
    box-shadow: 0 0 20px rgba(100, 255, 218, 0.15);
  }

  .lab-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
  }

  .lab-number {
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
  }

  .lab-status {
    font-size: 0.7rem;
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    gap: 6px;
    border: 1px solid;
  }

  .status-indicator {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    display: block;
  }

  .lab-status--activo {
    color: var(--green-bright);
    background: rgba(100, 255, 218, 0.08);
    border-color: rgba(100, 255, 218, 0.2);
  }
  .lab-status--activo .status-indicator {
    background: var(--green-bright);
    box-shadow: 0 0 6px var(--green-bright);
    animation: pulse-glow 2s infinite;
  }

  .lab-status--desplegado {
    color: #60a5fa;
    background: rgba(96, 165, 250, 0.08);
    border-color: rgba(96, 165, 250, 0.2);
  }
  .lab-status--desplegado .status-indicator {
    background: #60a5fa;
  }

  .lab-status--operativo {
    color: #ffa500;
    background: rgba(255, 165, 0, 0.08);
    border-color: rgba(255, 165, 0, 0.2);
  }
  .lab-status--operativo .status-indicator {
    background: #ffa500;
    box-shadow: 0 0 6px #ffa500;
    animation: pulse-glow 2.5s infinite;
  }

  /* Category */
  .lab-category {
    font-size: 0.75rem;
    color: var(--green-bright);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 10px;
    opacity: 0.8;
  }

  /* Title */
  .lab-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-bright);
    line-height: 1.3;
    margin-bottom: 14px;
  }

  /* Description */
  .lab-description {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 20px;
    flex-grow: 1;
  }

  /* Details list */
  .lab-details {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 22px;
  }

  .lab-detail-item {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-secondary);
    display: flex;
    align-items: baseline;
    gap: 8px;
    line-height: 1.5;
  }

  .lab-detail-item svg {
    color: var(--green-bright);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Tags */
  .lab-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 28px;
  }

  .lab-tag {
    font-size: 0.72rem;
    padding: 3px 10px;
    background: var(--bg-elevated);
    color: var(--text-muted);
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
    letter-spacing: 0.04em;
    transition: all var(--transition-fast);
  }

  .lab-tag:hover {
    color: var(--green-bright);
    border-color: var(--border-accent);
  }

  /* Actions */
  .lab-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .lab-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: all var(--transition-normal);
    flex: 1;
    justify-content: center;
    border: 1px solid;
  }

  .lab-btn--primary {
    background: var(--green-bright);
    color: var(--bg-void);
    border-color: var(--green-bright);
    font-weight: 700;
  }

  .lab-btn--primary:hover {
    background: #7fffd4;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(100, 255, 218, 0.3);
  }

  .lab-btn--secondary {
    background: transparent;
    color: var(--text-secondary);
    border-color: var(--border-subtle);
  }

  .lab-btn--secondary:hover {
    color: var(--green-bright);
    border-color: var(--border-accent);
    background: var(--green-dim);
    transform: translateY(-2px);
  }

  @media (max-width: 700px) {
    .labs-grid {
      grid-template-columns: 1fr;
    }
    .lab-card {
      padding: 24px 20px;
    }
  }
</style>
