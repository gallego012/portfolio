---
// Footer.astro — Minimalist terminal footer
const currentYear = new Date().getFullYear();
---

<footer class="site-footer" id="contacto">
  <div class="container footer-container">
    
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-logo mono">
          <span class="logo-bracket">[</span> root@nexus <span class="logo-bracket">]</span>
        </span>
        <p class="footer-tagline">
          Infraestructura como código.<br>
          Desplegado en la red Edge de Cloudflare.
        </p>
      </div>

      <div class="footer-links">
        <h4 class="footer-title mono">// Contacto</h4>
        <div class="contact-methods">
          <a href="mailto:cristiangallegosimon@outlook.com" class="contact-link" aria-label="Enviar correo electrónico">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            cristiangallegosimon@outlook.com
          </a>
          <a href="https://github.com/gallego012" target="_blank" rel="noopener noreferrer" class="contact-link" aria-label="Visitar perfil de GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="copyright mono">
        &copy; {currentYear} Cristian Gallego. Todos los derechos reservados.
      </p>
      <div class="status-badge" aria-label="Estado del sistema: Operativo">
        <span class="status-dot"></span>
        <span class="mono">Systems Online</span>
      </div>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-void);
    border-top: 1px solid var(--border-subtle);
    padding: 60px 0 30px;
    position: relative;
    z-index: 10;
  }

  .footer-container {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 40px;
  }

  .footer-brand {
    max-width: 380px;
  }

  .footer-logo {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 16px;
    display: inline-block;
  }

  .logo-bracket {
    color: var(--green-bright);
  }

  .footer-tagline {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .footer-title {
    font-size: 0.9rem;
    color: var(--green-bright);
    margin-bottom: 20px;
    letter-spacing: 0.1em;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1rem;
    color: var(--text-secondary);
    transition: all var(--transition-fast);
  }

  .contact-link:hover,
  .contact-link:focus {
    color: var(--green-bright);
    transform: translateX(4px);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
    padding-top: 30px;
    border-top: 1px dashed var(--border-subtle);
  }

  .copyright {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    color: var(--text-muted);
    background: var(--bg-elevated);
    padding: 6px 12px;
    border-radius: 4px;
    border: 1px solid var(--border-subtle);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    background: var(--green-bright);
    border-radius: 50%;
    box-shadow: 0 0 6px var(--green-bright);
    animation: pulse-glow 2s infinite;
  }

  @media (max-width: 640px) {
    .footer-top {
      flex-direction: column;
    }
    
    .footer-bottom {
      flex-direction: column-reverse;
      text-align: center;
    }
  }
</style>
